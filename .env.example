NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Required in production if SUPABASE_SERVICE_ROLE_KEY is not available.
SESSION_SECRET=
# Public base URL used by payment gateway callbacks, for example:
# NEXT_PUBLIC_APP_URL=https://siakad.example.ac.id
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Hosted Supabase/Postgres generally needs DATABASE_SSL=require.
# Local Docker PostgreSQL uses DATABASE_SSL=false.
DATABASE_URL=postgresql://siakad:siakad_password@localhost:5432/siakad
DIRECT_URL=postgresql://siakad:siakad_password@localhost:5432/siakad
DATABASE_SSL=false

# Future integrations from prompt aplikasi.
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
XENDIT_SECRET_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
